+  bp_be_commit_pkt_s next_commit_pkt_cast;
+
+  always_comb begin
+    // Similar to how we handle the register files, we need to set each wire to
+    // 0 in case the software set the context ID to an invalid ID. In that case,
+    // the for loop will never fill in this wires, so we need to make sure they
+    // are driven to 0.
+    csr_data_o = csr_data_co[curr_ctxt_o]; 
+    csr_illegal_instr_o = csr_illegal_instr_co[curr_ctxt_o];
+    csr_csrw_o = csr_csrw_co[curr_ctxt_o];
+    csr_ctxtsw_o = csr_ctxtsw_co[curr_ctxt_o]; 
+    irq_pending_o = irq_pending_co[curr_ctxt_o];
+    irq_waiting_o = irq_waiting_co[curr_ctxt_o]; 
+    commit_pkt_cast_o = commit_pkt_co[curr_ctxt_o];
+    decode_info_o = decode_info_co[curr_ctxt_o];
+    trans_info_o = trans_info_co[curr_ctxt_o];
+    frm_dyn_o = frm_dyn_co[curr_ctxt_o];
+    csr_cmd_v_ci = 0;
+    timer_irq_ci = 0;
+    software_irq_ci = 0;
+    external_irq_ci = 0;
+    fflags_acc_ci = 0; 
+    frf_w_v_ci = 0;
+    retire_pkt_ci = 0; 
+    csr_cmd_v_ci[curr_ctxt_o] = csr_cmd_v_i;
+    timer_irq_ci[curr_ctxt_o] = timer_irq_i;
+    software_irq_ci[curr_ctxt_o] = software_irq_i;
+    external_irq_ci[curr_ctxt_o] = external_irq_i;
+    fflags_acc_ci[curr_ctxt_o] = fflags_acc_i; 
+    frf_w_v_ci[curr_ctxt_o] = frf_w_v_i; 
+    retire_pkt_ci[curr_ctxt_o] = retire_pkt_i; 
+
+    // Make sure to set `next_commit_pkt` to zeroes on reset. Otherwise, we may
+    // end up accessing an invalid index in `commit_pkt_co` which could cause
+    // the design to hang.
+    //next_commit_pkt = (!reset_i && retire_pkt_cast_i.special.ctxtsw) ? commit_pkt_co[retire_pkt_cast_i.data[31:0]] : '0;
+    next_commit_pkt_cast = (!reset_i && retire_pkt_cast_i.special.ctxtsw) ? commit_pkt_co[retire_pkt_cast_i.data[31:0]] : '0;
+    commit_pkt_cast_o.npc_next_context              = next_commit_pkt_cast.npc;
+    commit_pkt_cast_o.translation_en_n_next_context = next_commit_pkt_cast.translation_en_n;
+    commit_pkt_cast_o.priv_n_next_context           = next_commit_pkt_cast.priv_n;
+    commit_pkt_cast_o.asid_next_context             = next_commit_pkt_cast.asid_next_context;
+  end
+
+  // Generate on CSR file per context.
+  genvar i;
+  generate 
+  for (i = 0; i < multithread_p; i++) begin: gen_csr
+    // TODO: I noticed that `gen_csr` is directly accessible from `csr_wrapper`
+    // in bp_top/test/tb/bp_tethered/testbench.sv. Do we not need to explicitly
+    // mark `gen_csr` as an output?
+    bp_be_csr
+      // Pass the context ID to `ctxt_id`.
+      #(.bp_params_p(bp_params_p), .ctxt_id(i))
+    csr
+      (.clk_i(clk_i)
+      ,.reset_i(reset_i)
+
+      ,.cfg_bus_i(cfg_bus_i)
+
+      // TODO: This was `csr_cmd_li` before it was changed to `csr_cmd_i` in
+      // commit 1eba80ee0d6f1fb3bfcbf2809f5c8f684935f55e. I assume `csr_cmd_li`
+      // was just a typo that unfortunately matched the name of a wire
+      // elsewhere? Is that all that commit was fixing or is there anything else
+      // to know?
+      ,.csr_cmd_i(csr_cmd_i)
+
+      // For all of the inputs below, we are passing the index corresponding to
+      // this context to the two-dimensional arrays.
+      ,.csr_cmd_v_i(csr_cmd_v_ci[i])
+      ,.csr_data_o(csr_data_co[i])
+      ,.csr_illegal_instr_o(csr_illegal_instr_co[i])
+      ,.csr_csrw_o(csr_csrw_co[i])
+      ,.csr_ctxtsw_o(csr_ctxtsw_co[i])
+
+      ,.fflags_acc_i(fflags_acc_ci[i])
+      ,.frf_w_v_i(frf_w_v_ci[i])
+
+      ,.timer_irq_i(timer_irq_ci[i])
+      ,.software_irq_i(software_irq_ci[i])
+      ,.external_irq_i(external_irq_ci[i])
+      ,.irq_pending_o(irq_pending_co[i])
+      ,.irq_waiting_o(irq_waiting_co[i])
+
+      ,.retire_pkt_i(retire_pkt_ci[i])
+      ,.commit_pkt_o(commit_pkt_co[i])
+      ,.decode_info_o(decode_info_co[i])
+      ,.trans_info_o(trans_info_co[i])
+      ,.frm_dyn_o(frm_dyn_co[i])
+     );
+  end
+  endgenerate 
+endmodule 
