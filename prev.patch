diff --git a/bp_be/src/v/bp_be_calculator/bp_be_csr_wrapper.sv b/bp_be/src/v/bp_be_calculator/bp_be_csr_wrapper.sv
new file mode 100644
index 00000000..691683f7
--- /dev/null
+++ b/bp_be/src/v/bp_be_calculator/bp_be_csr_wrapper.sv
@@ -0,0 +1,219 @@
+/**
+ *
+ * Name:
+ *   bp_be_csr_wrapper.v
+ *
+ * Description:
+ *   A wrapper around the CSR registers. Each context has its own copy of the
+ *   CSR registers. However, the ID of the context currently running on the hart
+ *   is also stored in a CSR (ctxt at 0x081) and accessed via csrr/csrw. There
+ *   should only be one ctxt register regardless of the number of contexts.
+ *   Thus, we have this wrapper since the wrapper holds the single ctxt CSR and
+ *   forwards requests for other CSRs to the CSR register file that corresponds
+ *   to the currently running context.
+ */
+`include "bp_common_defines.svh"
+`include "bp_be_defines.svh"
+
+module bp_be_csr_wrapper
+ import bp_common_pkg::*;
+ import bp_be_pkg::*;
+
+ // The beginning of this wrapper is essentially the same as the beginning of
+ // bp_be_csr.sv. We need to have the same localparameters and module interface
+ // as the CSR register file itself.
+ #(parameter bp_params_e bp_params_p = e_bp_default_cfg
+   `declare_bp_proc_params(bp_params_p)
+
+   , localparam csr_cmd_width_lp = $bits(bp_be_csr_cmd_s)
+
+   , localparam cfg_bus_width_lp = `bp_cfg_bus_width(hio_width_p, core_id_width_p, cce_id_width_p, lce_id_width_p)
+
+   , localparam commit_pkt_width_lp = `bp_be_commit_pkt_width(vaddr_width_p, paddr_width_p)
+   , localparam decode_info_width_lp = `bp_be_decode_info_width
+   , localparam trans_info_width_lp = `bp_be_trans_info_width(asid_width_p, ptag_width_p)
+   , localparam retire_pkt_width_lp = `bp_be_retire_pkt_width(vaddr_width_p)
+   )
+  (input                                     clk_i
+   , input                                   reset_i
+
+   , input [cfg_bus_width_lp-1:0]            cfg_bus_i
+
+   // CSR instruction interface
+   , input [csr_cmd_width_lp-1:0]            csr_cmd_i
+   , input                                   csr_cmd_v_i
+   , output logic [dword_width_gp-1:0]       csr_data_o
+   , output logic                            csr_illegal_instr_o
+   , output logic                            csr_csrw_o
+   , output logic                            csr_ctxtsw_o
+
+   // Misc interface
+   , input [retire_pkt_width_lp-1:0]         retire_pkt_i
+   , input rv64_fflags_s                     fflags_acc_i
+   , input                                   frf_w_v_i
+
+   // Interrupts
+   , input                                   timer_irq_i
+   , input                                   software_irq_i
+   , input                                   external_irq_i
+   , output logic                            irq_pending_o
+   , output logic                            irq_waiting_o
+
+   // The final commit packet
+   , output logic [commit_pkt_width_lp-1:0]  commit_pkt_o
+
+   // Slow signals
+   , output logic [decode_info_width_lp-1:0] decode_info_o
+   , output logic [trans_info_width_lp-1:0]  trans_info_o
+   , output rv64_frm_e                       frm_dyn_o
+   // `curr_ctxt_o` is the output read from the ctxt CSR.
+   // TODO: Shouldn't this be dword_width_gp-1:0 (or whatever the width of the
+   // max number of contexts is in bits, e.g., $bits(multithread_p)-1:0)?
+   , output logic [multithread_p-1:0]        curr_ctxt_o
+   );
+  
+  // Declare parameterizable structs
+  `declare_bp_cfg_bus_s(hio_width_p, core_id_width_p, cce_id_width_p, lce_id_width_p);
+  `declare_bp_be_internal_if_structs(vaddr_width_p, paddr_width_p, asid_width_p, branch_metadata_fwd_width_p);
+
+  //`declare_csr_structs(vaddr_width_p, paddr_width_p);
+  //`bp_cast_i(bp_cfg_bus_s, cfg_bus);
+  //`bp_cast_i(bp_be_csr_cmd_s, csr_cmd);
+  `bp_cast_i(bp_be_retire_pkt_s, retire_pkt);
+  `bp_cast_o(bp_be_commit_pkt_s, commit_pkt);
+  //bp_be_retire_pkt_s retire_pkt_temp_i;
+  //assign retire_pkt_temp_i = retire_pkt_i;
+  
+  /* CONTEXT REGISTER */
+  // This is a 32-bit flip-flop.
+  // TODO: Why not use `declare_csr()? I guess I need to look into
+  // `retire_pkt_cast_i.special.ctxtsw` and `retire_pkt_cast_i.data[31:0]` since
+  // `declare_csr() expects the input and output to have specific names.
+  bsg_dff_reset_en
+   // TODO: Shouldn't the width be dword_width_gp?
+   #(.width_p(32)
+    ,.reset_val_p(0            )) // reset to ctxt 0
+   ctxt_reg
+    (.clk_i(clk_i)
+     ,.reset_i(reset_i)
+     // Raise `en_i` if the flip-flop should update its output.
+     // `retire_pkt_cast_i.special.ctxtsw` is only a 1 when a csrw is issued for
+     // the ctxt CSR register. We only update the CTXT CSR register value when
+     // the instruction is at the end of the pipeline and retires.
+     ,.en_i(retire_pkt_cast_i.special.ctxtsw)
+     // The input to the flip-flop is the context ID that the last instruction
+     // wrote, if the last instruction was a csrw for the CTXT CSR
+     // (`retire_pkt_cast_i.special.ctxtsw` is 1 if so, 0 if not).
+     // TODO: Why do we need [31:0] at all instead of just
+     // `retire_pkt_cast_i.data`? Also, should we have `[dpath_width_gp-1:0]`
+     // instead (as in bp_be/src/include/bp_be_defines.svh)?
+     ,.data_i(retire_pkt_cast_i.data[31:0])
+     // The output of the flip-flop.
+     ,.data_o(curr_ctxt_o)
+    );
+
+  // Similar to how we duplicated the register files so we have one per context,
+  // we are duplicating the CSR files here so that there is one per context.
+  // Note that each wire is a two-dimensional array where there is one entry per
+  // context (multithread_p-1:0).
+  logic [multithread_p-1:0][dword_width_gp-1:0]   csr_data_co;
+  logic [multithread_p-1:0][commit_pkt_width_lp-1:0]  commit_pkt_co;
+  logic [multithread_p-1:0][decode_info_width_lp-1:0] decode_info_co;
+  logic [multithread_p-1:0][trans_info_width_lp-1:0]  trans_info_co;
+  logic [multithread_p-1:0][retire_pkt_width_lp-1:0]  retire_pkt_ci;
+  rv64_fflags_s [multithread_p-1:0]                   fflags_acc_ci;
+  rv64_frm_e    [multithread_p-1:0]                   frm_dyn_co;
+  logic [multithread_p-1:0] csr_cmd_v_ci, csr_illegal_instr_co, csr_csrw_co, csr_ctxtsw_co, timer_irq_ci, software_irq_ci, external_irq_ci, irq_pending_co, irq_waiting_co, frf_w_v_ci;
